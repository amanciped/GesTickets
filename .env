application_name=gestickets
datasource_url=jdbc:postgresql://localhost:5432/gestickets
datasource_username=postgres
datasource_password=1234
server_port=8081
jpa_hibernate_ddl-auto=update
jpa_properties_hibernate_dialect=org.hibernate.dialect.PostgreSQLDialect
jpa_show-sql=true
thymeleaf_prefix=classpath:/templates/
thymeleaf_suffix=.html
thymeleaf_enabled=true
application_name=bkedgame
